---
import Logo from "./Logo.astro";
import ThemeIcon from "./ThemeIcon.astro";
import { Icon } from 'astro-icon/components';

const { showHero = false } = Astro.props;
---

{showHero ? (
  <header class="fixed top-4 left-1/2 -translate-x-1/2 z-50 w-[calc(100%-2rem)] max-w-2xl">
    <div class="flex items-center justify-between h-12 px-4 sm:px-5
                bg-navbar backdrop-blur-2xl
                rounded-full border border-border/50
                shadow-[0_4px_24px_-4px_rgba(0,0,0,0.12)]">
      <Logo />
      <div class="flex items-center gap-2 sm:gap-4">
        <div class="hidden sm:flex items-center gap-4">
          <a href="/" class="text-sm font-medium text-slight-gray hover:text-foreground transition-colors">Home</a>
          <a href="/about/" class="text-sm font-medium text-slight-gray hover:text-foreground transition-colors">About</a>
          <a href="https://github.com/mahantybiplab/" target="_blank" class="text-slight-gray hover:text-foreground transition-colors" aria-label="GitHub"><Icon name="mdi:github" size={20} /></a>
          <a href="https://x.com/MahantyBiplab3" target="_blank" class="text-slight-gray hover:text-foreground transition-colors" aria-label="Twitter"><Icon name="x" size={16} /></a>
          <div class="w-px h-4 bg-border/50"></div>
        </div>
        <ThemeIcon />
        <button id="hamburger-btn" aria-label="Toggle menu"
          class="sm:hidden flex items-center justify-center w-8 h-8 rounded-full text-slight-gray hover:text-foreground transition-colors">
          <svg id="hamburger-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="hamburger-close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
            <path d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </header>
) : (
  <header class="sticky top-0 z-50 -mx-4 sm:-mx-8 md:-mx-16 px-4 sm:px-8 md:px-16 bg-navbar backdrop-blur-xl">
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border/30 to-transparent"></div>
    <div class="flex items-center justify-between h-14 max-w-5xl mx-auto">
      <Logo />
      <div class="flex items-center gap-3 sm:gap-5">
        <div class="hidden sm:flex items-center gap-5">
          <a href="/" class="text-sm font-medium text-slight-gray hover:text-foreground transition-colors">Home</a>
          <a href="/about/" class="text-sm font-medium text-slight-gray hover:text-foreground transition-colors">About</a>
          <a href="https://github.com/mahantybiplab/" target="_blank" class="text-slight-gray hover:text-foreground transition-colors" aria-label="GitHub"><Icon name="mdi:github" size={20} /></a>
          <a href="https://x.com/MahantyBiplab3" target="_blank" class="text-slight-gray hover:text-foreground transition-colors" aria-label="Twitter"><Icon name="x" size={16} /></a>
          <div class="w-px h-4 bg-border/40"></div>
        </div>
        <ThemeIcon />
        <button id="hamburger-btn" aria-label="Toggle menu"
          class="sm:hidden flex items-center justify-center w-8 h-8 rounded-lg text-slight-gray hover:text-foreground transition-colors">
          <svg id="hamburger-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="hamburger-close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
            <path d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </header>
)}

<!-- Full-screen overlay menu (shared) -->
<div id="mobile-overlay"
  class="fixed inset-0 z-40 pointer-events-none"
  aria-hidden="true">
  <!-- Backdrop -->
  <div id="overlay-backdrop"
    class="absolute inset-0 bg-body/80 backdrop-blur-xl opacity-0 transition-opacity duration-300"></div>
  <!-- Panel -->
  <div id="overlay-panel"
    class="absolute top-20 left-4 right-4 rounded-2xl border border-border/50
           bg-body/95 backdrop-blur-2xl shadow-[0_24px_64px_-12px_rgba(0,0,0,0.3)]
           opacity-0 -translate-y-3 transition-all duration-300 ease-out overflow-hidden">
    <nav class="flex flex-col p-2">
      <a href="/" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slight-gray hover:text-foreground hover:bg-card-hover transition-all duration-150 group">
        <span class="text-base font-medium">Home</span>
        <svg class="ml-auto w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6h8M7 3l3 3-3 3"/></svg>
      </a>
      <a href="/about/" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slight-gray hover:text-foreground hover:bg-card-hover transition-all duration-150 group">
        <span class="text-base font-medium">About</span>
        <svg class="ml-auto w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6h8M7 3l3 3-3 3"/></svg>
      </a>
      <div class="h-px bg-border/40 mx-4 my-1"></div>
      <div class="flex items-center gap-5 px-4 py-3">
        <a href="https://github.com/mahantybiplab/" target="_blank" aria-label="GitHub"
          class="text-slight-gray hover:text-foreground transition-colors">
          <Icon name="mdi:github" size={22} />
        </a>
        <a href="https://x.com/MahantyBiplab3" target="_blank" aria-label="Twitter"
          class="text-slight-gray hover:text-foreground transition-colors">
          <Icon name="x" size={18} />
        </a>
      </div>
    </nav>
  </div>
</div>

<script is:inline>
  function initMenu() {
    const btn = document.getElementById('hamburger-btn');
    const overlay = document.getElementById('mobile-overlay');
    const backdrop = document.getElementById('overlay-backdrop');
    const panel = document.getElementById('overlay-panel');
    const iconOpen = document.getElementById('hamburger-open');
    const iconClose = document.getElementById('hamburger-close');
    if (!btn || !overlay || !backdrop || !panel) return;

    let isOpen = false;

    function open() {
      isOpen = true;
      overlay.classList.remove('pointer-events-none');
      overlay.setAttribute('aria-hidden', 'false');
      backdrop.style.opacity = '1';
      panel.style.opacity = '1';
      panel.style.transform = 'translateY(0)';
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      isOpen = false;
      overlay.classList.add('pointer-events-none');
      overlay.setAttribute('aria-hidden', 'true');
      backdrop.style.opacity = '0';
      panel.style.opacity = '0';
      panel.style.transform = 'translateY(-12px)';
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      document.body.style.overflow = '';
    }

    btn.addEventListener('click', (e) => { e.stopPropagation(); isOpen ? close() : open(); });
    backdrop.addEventListener('click', close);
    panel.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });

    window.addEventListener('resize', () => { if (window.innerWidth >= 640) close(); });
  }

  initMenu();
  document.addEventListener('astro:after-swap', initMenu);
</script>
