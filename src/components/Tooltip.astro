---
export interface Props {
  text: string;
}
const { text } = Astro.props;
---

<span class="tooltip-trigger group relative inline-block cursor-help border-b border-dotted border-current">
  <slot />
  
  <span class="tooltip-content hidden group-hover:block absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-max max-w-[calc(100vw-2rem)] sm:max-w-xs bg-menu text-foreground text-sm px-3 py-1.5 rounded-lg shadow-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50 whitespace-normal wrap-break-word border border-border mx-auto">
    {text}
  </span>
</span>

<script is:inline>
  if (typeof window !== 'undefined' && !window.tooltipScriptLoaded) {
    window.tooltipScriptLoaded = true;

    document.addEventListener('mouseover', (e) => {
      const trigger = e.target.closest('.tooltip-trigger');
      if (!trigger) return;

      const tooltip = trigger.querySelector('.tooltip-content');
      if (!tooltip) return;

      // Ensure the "hidden" class is removed or display is active before measuring
      // Tailwind's group-hover:block handles this, but we need a tiny 
      // frame delay to let the browser calculate the new position.
      requestAnimationFrame(() => {
        tooltip.style.setProperty('--tw-translate-x', '-50%');

        const rect = tooltip.getBoundingClientRect();
        const padding = 16;

        if (rect.left < padding) {
          const nudge = padding - rect.left;
          tooltip.style.setProperty('--tw-translate-x', `calc(-50% + ${nudge}px)`);
        } else if (rect.right > window.innerWidth - padding) {
          const nudge = rect.right - (window.innerWidth - padding);
          tooltip.style.setProperty('--tw-translate-x', `calc(-50% - ${nudge}px)`);
        }
      });
    });
  }
</script>