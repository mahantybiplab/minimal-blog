---
export interface Props {
  text: string;
}
const { text } = Astro.props;
---

<span class="tooltip-trigger group relative inline-block cursor-help border-b border-dotted border-current">
  <slot />
  
  <span class="tooltip-content absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-max max-w-[calc(100vw-2rem)] sm:max-w-xs bg-menu text-foreground text-sm px-3 py-1.5 rounded-lg shadow-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50 whitespace-normal wrap-break-word border border-border mx-auto">
    {text}
  </span>
</span>

<script is:inline>
  // We wrap this in a check so the event listener is only added once per page, 
  // even if you use 100 tooltips in a single blog post.
  if (typeof window !== 'undefined' && !window.tooltipScriptLoaded) {
    window.tooltipScriptLoaded = true;

    document.addEventListener('mouseover', (e) => {
      // Find out if we are hovering over a tooltip
      const trigger = e.target.closest('.tooltip-trigger');
      if (!trigger) return;

      const tooltip = trigger.querySelector('.tooltip-content');
      if (!tooltip) return;

      // Reset the translation to default center before measuring
      tooltip.style.setProperty('--tw-translate-x', '-50%');

      // Measure where the tooltip currently sits on the screen
      const rect = tooltip.getBoundingClientRect();
      const padding = 16; // Keep it 16px away from the screen edges

      if (rect.left < padding) {
        // If it bleeds off the LEFT side, calculate the difference and nudge it right
        const nudge = padding - rect.left;
        tooltip.style.setProperty('--tw-translate-x', `calc(-50% + ${nudge}px)`);
        
      } else if (rect.right > window.innerWidth - padding) {
        // If it bleeds off the RIGHT side, calculate the difference and nudge it left
        const nudge = rect.right - (window.innerWidth - padding);
        tooltip.style.setProperty('--tw-translate-x', `calc(-50% - ${nudge}px)`);
      }
    });
  }
</script>