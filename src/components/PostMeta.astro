---
const { frontmatter } = Astro.props;
const { pubDate, tags, title, subtitle } = frontmatter;

// Format dates
const shortDate = new Date(pubDate).toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
});

function formatDateWithOrdinal(dateString: string) {
  const date = new Date(dateString);
  const day = date.getDate();
  const suffix =
    day % 10 === 1 && day !== 11
      ? "st"
      : day % 10 === 2 && day !== 12
        ? "nd"
        : day % 10 === 3 && day !== 13
          ? "rd"
          : "th";
  const month = date.toLocaleString("en-US", { month: "long" });
  const year = date.getFullYear();
  return `${month} ${day}${suffix}, ${year}`;
}

const fullDate = formatDateWithOrdinal(frontmatter.pubDate);
---

<div
  class="relative inset-x-0 pt-0 md:max-lg:flex md:max-lg:flex-col md:max-lg:items-center md:max-lg:text-center"
>
  <h1
    class="mb-5 wrap-break-word [hyphens:auto] [-webkit-hyphens:auto] max-w-full text-balance"
  >
    {title && <span class="text-4xl block leading-[1.3]">{title}</span>}
    {
      subtitle && (
        <span class="text-xl text-article-subtitle font-normal mb-8 mt-1 block">
          {subtitle}
        </span>
      )
    }
  </h1>
  <dl
    class="not-prose flex flex-wrap gap-x-2 items-center text-slight-gray font-medium leading-tight"
  >
    <!-- Filed under -->
    <dt class="italic opacity-70">Filed under</dt>

    <!-- Tag link -->
    <dd>
      <a
        href={`/tags/${tags?.[0]}/`}
        class="no-underline text-nav transition-colors"
      >
        {tags?.[0]}
      </a>
    </dd>

    <!-- 'on' label -->
    <dt class="italic opacity-70">on</dt>

    <!-- Full date (desktop) -->
    <dd class="hidden md:inline text-slight-gray/80">
      {fullDate}
      <span class="opacity-50">.</span>
    </dd>

    <!-- Short date (mobile) -->
    <dd class="inline md:hidden text-slight-gray/80">
      {shortDate}
    </dd>
  </dl>
</div>
