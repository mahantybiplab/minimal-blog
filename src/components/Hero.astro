<section class="relative flex items-center justify-center h-[56vh] overflow-hidden">
  <!-- Dot grid overlay -->
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none opacity-40 dark:opacity-20"
    style="background-image: radial-gradient(circle, var(--border-color) 1px, transparent 1px); background-size: 28px 28px;">
  </div>

  <!-- Central glow orb -->
  <div aria-hidden="true" class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <div class="w-[600px] h-[300px] rounded-full
                bg-[radial-gradient(ellipse_at_center,var(--glow-color),transparent_70%)]
                blur-[80px]"></div>
  </div>

  <!-- Fade to body at bottom -->
  <div aria-hidden="true" class="absolute bottom-0 left-0 right-0 h-32
       bg-gradient-to-t from-body to-transparent pointer-events-none"></div>

  <!-- Content -->
  <div class="relative z-10 text-center px-4 select-none">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-border
                text-xs font-medium text-slight-gray mb-6 backdrop-blur-sm bg-body/40">
      <span class="w-1.5 h-1.5 rounded-full bg-nav animate-pulse"></span>
      Personal Blog
    </div>
    <h1 class="text-6xl sm:text-8xl font-bold tracking-tighter leading-[0.95]">
      <span class="bg-gradient-to-b from-foreground via-foreground to-foreground/30 bg-clip-text text-transparent">
        Curiosity
      </span>
    </h1>
    <p class="mt-4 text-base sm:text-lg font-light tracking-[0.25em] uppercase text-slight-gray">
      Beyond Code
    </p>
  </div>
</section>
