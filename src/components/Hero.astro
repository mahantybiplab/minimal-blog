---
import { Image } from 'astro:assets';
import ensoGraphic from '../assets/enso_feature_graphic.png';
---

<section id="hero" class="relative flex items-center justify-center overflow-hidden pt-10 md:pt-16 pb-8 md:pb-12">




  <!-- Content Container -->
  <div class="relative z-10 w-full max-w-6xl mx-auto px-5 sm:px-8 md:px-12 grid grid-cols-1 lg:grid-cols-[1.2fr_0.8fr] lg:grid-rows-[auto_auto_auto] gap-y-4 sm:gap-y-5 lg:gap-y-0 lg:gap-x-12 items-center lg:items-start place-content-center min-h-[65vh]">
    
    <!-- Group A: Badge & Headline -->
    <div class="order-2 lg:col-start-1 lg:row-start-1 flex flex-col items-start w-full lg:mb-6">
      <!-- Elegant Badge -->
      <a href="https://play.google.com/store/apps/details?id=com.mahantybiplab.ensomori" target="_blank" 
         class="hero-slide-in group inline-flex items-center gap-2.5 px-3 py-1.5 md:px-4 md:py-1.5 rounded-full 
                border border-border/60 bg-body/50 backdrop-blur-sm
                hover:border-nav/40 transition-all duration-500 mb-3 md:mb-5"
         style="--delay: 0s;">
        <!-- Glowing Status Dot (Left) -->
        <div class="relative flex h-1.5 w-1.5 md:h-2 md:w-2">
          <span class="absolute inline-flex h-full w-full rounded-full bg-nav opacity-50 animate-ping" style="animation-duration: 3s;"></span>
          <span class="relative inline-flex rounded-full h-full w-full bg-nav transition-all duration-500 group-hover:shadow-[0_0_8px_var(--color-primary)]"></span>
        </div>
        <span class="text-[10px] md:text-[11px] uppercase tracking-[0.15em] font-semibold text-slight-gray group-hover:text-foreground transition-colors duration-500">
          Building EnsoMori
        </span>
      </a>

      <!-- Headline (Recursive font, typewriter via JS) -->
      <h1 class="hero-slide-in mb-2 md:mb-4 w-full" style="--delay: 0.15s; font-family: 'Recursive', monospace;">
        <span id="tw-line1" class="block text-[1.4rem] sm:text-[2rem] lg:text-[2.75rem] font-bold tracking-tight leading-[1.1] text-foreground w-full">&nbsp;</span>
        <span id="tw-line2" class="block text-[1.4rem] sm:text-[2rem] lg:text-[2.75rem] font-bold tracking-tight leading-[1.1] text-foreground">&nbsp;</span>
      </h1>
      
      <!-- Tagline -->
      <p class="hero-slide-in text-[11px] sm:text-[13px] uppercase tracking-[0.2em] font-medium text-nav text-wrap break-words"
         style="--delay: 0.3s;">
        Privacy-first · Gentle App Interruption · 100% Offline
      </p>
    </div>

    <!-- Image -->
    <div class="hero-slide-in order-1 lg:col-start-2 lg:row-start-1 lg:row-span-3 flex justify-center w-full max-w-[180px] sm:max-w-[220px] md:max-w-[260px] lg:max-w-[340px] mx-auto relative lg:self-center"
         style="--delay: 0.35s;">
      <div class="relative group">
        
        <!-- Enso circle glow layers -->
        <div class="enso-glow enso-glow-outer"></div>
        <div class="enso-glow enso-glow-inner"></div>

        <!-- Animated border card -->
        <div class="hero-card-wrapper">
          <div class="hero-card-border"></div>
          <div class="hero-card-content relative">
            <Image 
              src={ensoGraphic} 
              alt="EnsoMori Feature Graphic" 
              class="w-full h-auto relative z-10"
            />
            <!-- Middle Enso glow overlay -->
            <div class="absolute inset-0 flex items-center justify-center z-20 pointer-events-none">
              <div class="enso-middle-glow"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Body Text -->
    <p class="hero-slide-in order-3 lg:col-start-1 lg:row-start-2 text-[14px] sm:text-[15px] lg:text-[16px] text-slight-gray max-w-full lg:max-w-2xl lg:mb-6 leading-[1.6] text-wrap break-words text-justify"
       style="--delay: 0.45s;">
      I'm Biplab. I build <span class="text-foreground font-medium">EnsoMori</span> — an offline Android companion that turns <span class="text-foreground font-medium">mindless scrolling into moments of self-discovery</span>. If you're tired of strict app blockers and relying on <span class="text-foreground font-medium">sheer willpower</span>, EnsoMori offers a different path. Through <span class="text-foreground font-medium">gentle app interruptions</span>, a <span class="text-foreground font-medium">daily journal</span>, and forgiving check-ins, it builds <span class="text-foreground font-medium">effortless awareness</span>. Because real change only occurs when we stop resisting and learn to be with <span class="text-foreground italic">what is</span>, it helps you understand your deepest habits and <span class="text-foreground font-medium">change without trying to change</span>.
    </p>

    <!-- Actions -->
    <div class="hero-slide-in order-4 lg:col-start-1 lg:row-start-3 flex flex-wrap max-[400px]:flex-col max-[400px]:w-full max-[400px]:items-center items-center gap-3 lg:gap-4 pb-4 lg:pb-0"
         style="--delay: 0.6s;">
      <a href="https://play.google.com/store/apps/details?id=com.mahantybiplab.ensomori" target="_blank" 
         class="hero-cta group relative px-3.5 py-1.5 md:px-5 md:py-2.5 lg:px-6 lg:py-3 rounded-full bg-foreground text-body text-[11px] md:text-[13px] lg:text-[14px] font-semibold tracking-wide overflow-hidden
                transition-all duration-300">
        <span class="relative z-10">Get the App</span>
        <div class="hero-cta-shine"></div>
      </a>
      <a href="#posts" 
         class="hero-border-glow px-3.5 py-1.5 md:px-5 md:py-2.5 lg:px-6 lg:py-3 rounded-full border border-border text-slight-gray text-[11px] md:text-[13px] lg:text-[14px] font-semibold tracking-wide 
                hover:text-foreground transition-all duration-300">
        Read Articles
      </a>
    </div>
    
  </div>
</section>

<style>


  /* ─── Middle Enso Glow ─── */
  .enso-middle-glow {
    width: 140px;
    height: 140px;
    background: radial-gradient(circle, var(--color-primary) 0%, transparent 70%);
    opacity: 0.18;
    filter: blur(20px);
    mix-blend-mode: plus-lighter;
  }

  /* ─── Staggered Slide-In ─── */
  .hero-slide-in {
    opacity: 0;
    transform: translateY(40px) scale(0.97);
    animation: slideIn 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0s);
  }
  @keyframes slideIn {
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ─── Typewriter Caret ─── */
  .typewriter-caret {
    display: inline-block;
    width: 3px;
    height: 1.1em;
    background: var(--color-primary);
    margin-left: 4px;
    vertical-align: text-bottom;
    animation: caretBlink 0.7s step-end infinite;
  }
  @keyframes caretBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }



  /* ─── CTA Button ─── */
  .hero-cta:hover {
    transform: scale(1.04);
    box-shadow: 0 8px 40px -8px var(--glow-color);
  }
  .hero-cta-shine {
    position: absolute; top: 0; left: -100%;
    width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  }
  .hero-cta:hover .hero-cta-shine {
    animation: ctaShine 0.6s ease-out forwards;
  }
  @keyframes ctaShine { to { left: 100%; } }

  .hero-border-glow:hover {
    border-color: var(--color-primary);
    box-shadow: 0 0 20px -5px var(--glow-color), inset 0 0 20px -12px var(--glow-color);
  }

  /* ─── Enso Circle Glow (two layers for depth) ─── */
  .enso-glow {
    position: absolute;
    top: 50%; left: 50%;
    border-radius: 50%;
    z-index: 0;
    pointer-events: none;
    transform: translate(-50%, -50%);
  }

  @keyframes glowBreatheOuter {
    0%, 100% { opacity: 0.15; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.25; transform: translate(-50%, -50%) scale(1.15); }
  }

  @keyframes glowBreatheInner {
    0%, 100% { opacity: 0.25; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.4; transform: translate(-50%, -50%) scale(1.2); }
  }

  .enso-glow-outer {
    width: 80%; height: 80%;
    background: var(--color-primary);
    filter: blur(60px);
    animation: glowBreatheOuter 8s ease-in-out infinite;
  }

  .enso-glow-inner {
    width: 40%; height: 40%;
    background: var(--color-primary);
    filter: blur(30px);
    animation: glowBreatheInner 8s ease-in-out infinite;
    animation-delay: 1s;
  }

  /* ─── Animated Border Card ─── */
  .hero-card-wrapper {
    position: relative;
    border-radius: 1rem;
    padding: 1.5px;
    animation: cardFloat 7s ease-in-out infinite;
  }

  .hero-card-border {
    position: absolute;
    inset: -1.5px;
    border-radius: 1rem;
    background: conic-gradient(
      from var(--card-angle, 0deg),
      var(--color-primary) 0%,
      transparent 12%,
      transparent 45%,
      var(--color-primary) 55%,
      transparent 67%,
      transparent 100%
    );
    animation: rotateBorder 4s linear infinite;
  }

  /* Extra solid border underneath so it's always visible */
  .hero-card-wrapper::before {
    content: '';
    position: absolute;
    inset: -1.5px;
    border-radius: 1rem;
    border: 1px solid var(--color-primary);
    opacity: 0.35;
  }

  .hero-card-content {
    position: relative;
    z-index: 1;
    border-radius: calc(1rem - 1.5px);
    overflow: hidden;
    background: var(--bg-body);
  }

  @property --card-angle {
    syntax: "<angle>";
    initial-value: 0deg;
    inherits: false;
  }

  @keyframes rotateBorder { to { --card-angle: 360deg; } }
  @keyframes cardFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
</style>

<script>
  function initHero() {
    // ── Typewriter (two-line, sequential) ──
    const line1El = document.getElementById('tw-line1');
    const line2El = document.getElementById('tw-line2');
    if (line1El && line2El) {
      const phrases = [
        ['Change Without', 'Trying To Change.'],
        ['Gentle App', 'Interruptions.'],
        ['30 Days', 'Self Inquiry.'],
        ['1 Journal.', '3 Check-ins.'],
        ['Log Moments.', 'Find Clarity.'],
        ['Understand', 'Yourself.']
      ];
      let phraseIdx = 0;
      let phase = 'type1'; // type1, type2, pause, del2, del1, wait
      let charIdx = 0;

      function updateText(el, text, showCaret) {
        let content = text || '&nbsp;';
        if (showCaret) {
          content += '<span class="typewriter-caret"></span>';
        }
        el.innerHTML = content;
      }

      function tick() {
        const [l1, l2] = phrases[phraseIdx];

        if (phase === 'type1') {
          charIdx++;
          const currentText = l1.slice(0, charIdx);
          updateText(line1El, currentText, true);
          updateText(line2El, '', false);
          if (charIdx >= l1.length) { 
            phase = 'type2'; 
            charIdx = 0; 
            setTimeout(tick, 200);
          } else {
            setTimeout(tick, 80);
          }
        } else if (phase === 'type2') {
          charIdx++;
          const currentText = l2.slice(0, charIdx);
          updateText(line1El, l1, false);
          updateText(line2El, currentText, true);
          if (charIdx >= l2.length) { 
            phase = 'pause'; 
            setTimeout(tick, 2500);
          } else {
            setTimeout(tick, 80);
          }
        } else if (phase === 'pause') {
          phase = 'del2';
          charIdx = l2.length;
          tick();
        } else if (phase === 'del2') {
          charIdx--;
          const currentText = l2.slice(0, charIdx);
          updateText(line1El, l1, false);
          updateText(line2El, currentText, true);
          if (charIdx <= 0) { 
            phase = 'del1'; 
            charIdx = l1.length; 
            setTimeout(tick, 150);
          } else {
            setTimeout(tick, 40);
          }
        } else if (phase === 'del1') {
          charIdx--;
          const currentText = l1.slice(0, charIdx);
          updateText(line1El, currentText, true);
          updateText(line2El, '', false);
          if (charIdx <= 0) { 
            phase = 'wait'; 
            setTimeout(tick, 400);
          } else {
            setTimeout(tick, 40);
          }
        } else if (phase === 'wait') {
          phraseIdx = (phraseIdx + 1) % phrases.length;
          phase = 'type1';
          charIdx = 0;
          tick();
        }
      }

      setTimeout(tick, 600);
    }




  }

  initHero();
  document.addEventListener('astro:after-swap', initHero);
</script>
