---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import "../styles/global.css";

const { pageTitle, showHero = false } = Astro.props;
---

<html lang="en" class="bg-body overscroll-none">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
      integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
      crossorigin="anonymous"
    />
    <script is:inline>
      const theme = (() => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          return "dark";
        }
        return "light";
      })();

      if (theme === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        document.documentElement.classList.add("dark");
      }
      window.localStorage.setItem("theme", theme);
    </script>
  </head>
  <body
    class="text-foreground font-sans overflow-x-hidden transition-colors duration-300 px-4 sm:px-8 md:px-16"
  >
    <Header />
    {showHero && <Hero />}
    <main>
      <slot />
      <Footer />
    </main>

    <script is:inline>
      const copyIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;
      const checkIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;

      function extractCalloutText(calloutEl) {
        const tempDiv = document.createElement("div");
        tempDiv.style.position = "absolute";
        tempDiv.style.left = "-9999px";
        tempDiv.style.whiteSpace = "pre";
        document.body.appendChild(tempDiv);

        const clone = calloutEl.cloneNode(true);
        tempDiv.appendChild(clone);

        clone
          .querySelectorAll(".callout-copy-btn, .copy-btn")
          .forEach((el) => el.remove());
        clone
          .querySelectorAll('.code-block-wrapper span[class*="absolute"]')
          .forEach((el) => el.remove());

        // A. KATEX → RAW LATEX
        clone
          .querySelectorAll("annotation[encoding='application/x-tex']")
          .forEach((annotation) => {
            const tex = annotation.textContent.trim();
            const katexNode = annotation.closest(".katex");
            if (!katexNode) return;

            const displayWrapper = katexNode.closest(".katex-display");
            const isBlock =
              !!displayWrapper ||
              katexNode.getAttribute("data-is-block") === "true";

            let rawTex;
            if (isBlock) {
              rawTex = tex.includes("\n") ? `$$\n${tex}\n$$` : `$$${tex}$$`;
            } else {
              rawTex = `$${tex}$`;
            }

            const target = displayWrapper || katexNode;
            target.replaceWith(document.createTextNode(rawTex));
          });

        // B. CODE BLOCKS → fenced markdown
        clone.querySelectorAll("pre").forEach((pre) => {
          const code = pre.querySelector("code");
          if (!code) return;

          const wrapper = pre.closest(".code-block-wrapper");
          let lang =
            pre.getAttribute("data-language") ||
            pre.getAttribute("data-lang") ||
            wrapper?.getAttribute("data-language") ||
            Array.from(code.classList)
              .find((c) => c.startsWith("language-"))
              ?.replace("language-", "") ||
            Array.from(pre.classList)
              .find((c) => c.startsWith("language-"))
              ?.replace("language-", "") ||
            "";

          const tempPre = document.createElement("pre");
          tempPre.style.whiteSpace = "pre";
          tempPre.appendChild(code.cloneNode(true));
          document.body.appendChild(tempPre);
          const codeText = tempPre.innerText.trim();
          document.body.removeChild(tempPre);

          const fenced = `\`\`\`${lang}\n${codeText}\n\`\`\``;
          const replaceTarget = wrapper || pre;
          replaceTarget.replaceWith(document.createTextNode(fenced));
        });

        // C. TITLE + FOLD CHAR
        const type = clone.getAttribute("data-callout") || "note";

        let foldChar = "";
        const foldAttr = calloutEl.getAttribute("data-callout-fold");
        if (foldAttr !== null) {
          foldChar = foldAttr === "-" ? "-" : "+";
        } else {
          const detailsEl =
            (calloutEl.tagName?.toLowerCase() === "details"
              ? calloutEl
              : null) ||
            calloutEl.closest("details") ||
            calloutEl.querySelector("details");
          if (detailsEl) {
            foldChar = detailsEl.hasAttribute("open") ? "-" : "+";
          }
        }

        const titleEl = clone.querySelector(".callout-title");
        let titleText = "";
        if (titleEl) {
          titleEl
            .querySelectorAll(".callout-icon, .callout-fold, svg, button")
            .forEach((el) => el.remove());
          titleText = titleEl.textContent.trim();
          titleEl.remove();
        }

        const autoTitle = type.charAt(0).toUpperCase() + type.slice(1);
        const titlePart =
          titleText && titleText.toLowerCase() !== type.toLowerCase()
            ? ` ${titleText}`
            : "";
        const headerLine = `> [!${type}]${foldChar}${titlePart}\n`;

        // D. INLINE FORMATTING
        for (let i = 1; i <= 6; i++) {
          clone.querySelectorAll(`h${i}`).forEach((h) => {
            h.prepend(`${"#".repeat(i)} `);
            h.append("\n");
          });
        }
        clone.querySelectorAll("strong, b").forEach((el) => {
          el.prepend("**");
          el.append("**");
        });
        clone.querySelectorAll("em, i").forEach((el) => {
          el.prepend("*");
          el.append("*");
        });

        // E. EXTRACT + PREFIX
        const bodyText = tempDiv.innerText.trim();
        const lines = bodyText.split("\n");
        const prefixedLines = lines.map((line) =>
          line.trim() === "" ? ">" : `> ${line}`,
        );
        let result = prefixedLines.join("\n");

        // Insert blank > line between consecutive $$ blocks
        result = result.replace(/\n(> \$\$)\n(> \$\$)/g, "\n$1\n>\n$2");

        document.body.removeChild(tempDiv);

        return headerLine + result;
      }

      function setupCalloutCopy() {
        document.querySelectorAll(".callout").forEach((callout) => {
          if (callout.querySelector(".callout-copy-btn")) return;
          const title = callout.querySelector(".callout-title");
          if (!title) return;

          callout.style.position = "relative";
          callout.style.overflow = "visible";

          const btn = document.createElement("button");
          btn.innerHTML = `<span class="icon">${copyIcon}</span><span class="text">Copy</span>`;
          btn.className =
            "callout-copy-btn absolute top-3 right-3 flex items-center gap-1 transition-all cursor-pointer text-[10px] font-bold uppercase tracking-wider z-20";
          btn.style.color = "var(--color-foreground)";

          btn.addEventListener("mouseenter", () => {
            btn.style.color = "var(--color-logo)";
          });
          btn.addEventListener("mouseleave", () => {
            btn.style.color = "var(--color-foreground)";
          });
          callout.appendChild(btn);

          btn.addEventListener("click", async () => {
            const rawText = extractCalloutText(callout);
            try {
              await navigator.clipboard.writeText(rawText);
              btn.querySelector(".icon").innerHTML = checkIcon;
              btn.querySelector(".text").innerText = "Copied!";
              btn.style.color = "#4ade80";
              setTimeout(() => {
                btn.querySelector(".icon").innerHTML = copyIcon;
                btn.querySelector(".text").innerText = "Copy";
                btn.style.color = "";
              }, 2000);
            } catch (err) {
              console.error("Failed to copy!", err);
            }
          });
        });
      }

      function setupCodeBlocks() {
        document.querySelectorAll("pre").forEach((pre) => {
          if (pre.closest(".code-block-wrapper")) return;
          const wrapper = document.createElement("div");
          wrapper.className = "code-block-wrapper relative";
          pre.parentNode.insertBefore(wrapper, pre);
          wrapper.appendChild(pre);

          let lang =
            pre.getAttribute("data-language") || pre.getAttribute("data-lang");
          if (!lang) {
            const code = pre.querySelector("code");
            if (code) {
              const langClass = Array.from(code.classList).find((c) =>
                c.startsWith("language-"),
              );
              if (langClass) lang = langClass.replace("language-", "");
            }
          }
          lang = lang || "code";

          const langLabel = document.createElement("span");
          langLabel.className =
            "absolute top-3 left-4 text-[10px] font-mono text-foreground/30 dark:text-white/30 uppercase tracking-[0.2em] font-bold z-20 select-none pointer-events-none";
          langLabel.innerText = lang;

          const btn = document.createElement("button");
          btn.className =
            "copy-btn absolute top-3 right-4 flex items-center gap-1.5 text-foreground/40 dark:text-white/40 hover:text-foreground dark:hover:text-white transition-all cursor-pointer text-[11px] font-bold uppercase tracking-wider z-20 select-none";
          btn.innerHTML = `<span class="icon">${copyIcon}</span><span class="text">Copy</span>`;

          wrapper.appendChild(langLabel);
          wrapper.appendChild(btn);
          pre.style.paddingTop = "2.5rem";

          const icon = btn.querySelector(".icon");
          const text = btn.querySelector(".text");

          btn.addEventListener("click", async () => {
            const codeText =
              pre.querySelector("code")?.innerText || pre.innerText;
            try {
              await navigator.clipboard.writeText(codeText);
              icon.innerHTML = checkIcon;
              text.innerText = "Copied!";
              btn.style.color = "#4ade80";
              setTimeout(() => {
                icon.innerHTML = copyIcon;
                text.innerText = "Copy";
                btn.style.color = "";
              }, 2000);
            } catch (err) {
              console.error("Failed to copy!", err);
            }
          });
        });
      }

      function init() {
        setupCodeBlocks();
        setupCalloutCopy();
      }

      init();
      document.addEventListener("astro:after-swap", init);
      document.addEventListener("DOMContentLoaded", init);
    </script>
  </body>
</html>
